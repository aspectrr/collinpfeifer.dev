---
interface Props {
    /** Highlights the matching nav item. Omit to leave none active (e.g. home). */
    active?: "blog" | "sessions" | "poker";
    /** Render the site name as an <h1> (home) instead of a link back to "/". */
    home?: boolean;
    /** Show the "Craftsman…" tagline under the nav. Default: true. */
    tagline?: boolean;
}

const { active, home = false, tagline = true } = Astro.props;

const nav: Array<{
    href: string;
    label: string;
    key: string;
    external?: boolean;
}> = [
    { href: "/blog", label: "blog", key: "blog" },
    { href: "/coding-sessions", label: "sessions", key: "sessions" },
    { href: "/poker", label: "poker", key: "poker" },
    {
        href: "https://github.com/aspectrr",
        label: "github",
        key: "github",
        external: true,
    },
];
---

<header class="relative px-6 py-24 overflow-hidden">
    <img
        src="/art/G-fD3zSWMAAv6L4.jpeg"
        alt=""
        aria-hidden="true"
        class="absolute inset-0 w-full h-full object-cover opacity-25 pointer-events-none"
        style="mask-image: linear-gradient(to bottom, black 70%, transparent); -webkit-mask-image: linear-gradient(to bottom, black 70%, transparent);"
    />
    <div class="relative z-10 mx-auto max-w-2xl">
        <div class="flex justify-between items-center mb-6 gap-3">
            {
                home ? (
                    <h1 class="text-lg xs:text-xl sm:text-2xl md:text-3xl tracking-tight font-logo">
                        Collin Pfeifer
                    </h1>
                ) : (
                    <a
                        href="/"
                        class="text-lg xs:text-xl sm:text-2xl md:text-3xl tracking-tight font-logo no-underline hover:no-underline text-white whitespace-nowrap"
                    >
                        Collin Pfeifer
                    </a>
                )
            }
            <nav
                class="flex gap-2.5 xs:gap-3 sm:gap-5 md:gap-6 text-xs xs:text-sm font-mono text-neutral-400"
                aria-label="Primary"
            >
                {
                    nav.map((item) => (
                        <a
                            href={item.href}
                            target={item.external ? "_blank" : undefined}
                            rel={
                                item.external
                                    ? "noopener noreferrer"
                                    : undefined
                            }
                            class={
                                active === item.key
                                    ? "text-neutral-200 whitespace-nowrap"
                                    : "hover:text-neutral-200 transition-colors whitespace-nowrap"
                            }
                        >
                            {item.label}
                        </a>
                    ))
                }
            </nav>
        </div>

        {
            tagline && (
                <p class="mt-2 text-neutral-400">
                    Craftsman. Working on 🌵{" "}
                    <a
                        href="https://madcactus.org"
                        target="_blank"
                        class="hover:text-neutral-200 transition-colors"
                        rel="noopener noreferrer"
                    >
                        Mad Cactus
                    </a>
                </p>
            )
        }

        <slot />
    </div>
</header>

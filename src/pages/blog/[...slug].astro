---
import { type CollectionEntry, getCollection } from "astro:content";
import Layout from "../../layouts/Layout.astro";
import { Image } from "astro:assets";

export async function getStaticPaths() {
    const posts = await getCollection("blog", ({ data }) => !data.draft);
    return posts.map((post) => ({
        params: { slug: post.slug },
        props: post,
    }));
}
type Props = CollectionEntry<"blog">;

const post = Astro.props;
const { Content } = await post.render();
---

<Layout title={post.data.title}>
    <div class="min-h-screen text-white bg-black">
        <header class="relative px-6 py-24 overflow-hidden">
            <Image
                src="/art/G-fD3zSWMAAv6L4.jpeg"
                width=100
                height=100
                alt=""
                aria-hidden="true"
                class="absolute inset-0 w-full h-full object-cover opacity-25 pointer-events-none"
                style="mask-image: linear-gradient(to bottom, black 70%, transparent); -webkit-mask-image: linear-gradient(to bottom, black 70%, transparent);"
            />
            <div class="relative z-10 mx-auto max-w-2xl">
                <div class="flex justify-between items-center mb-6">
                    <a
                        href="/"
                        class="text-2xl tracking-tight md:text-3xl font-logo no-underline hover:no-underline text-white"
                    >
                        Collin Pfeifer
                    </a>
                    <div class="flex gap-6 text-sm font-mono text-neutral-400">
                        <a href="/blog" class="hover:text-neutral-200 transition-colors">blog</a>
                        <a href="/coding-sessions" class="hover:text-neutral-200 transition-colors">sessions</a>
                        <a
                            href="https://github.com/aspectrr"
                            target="_blank"
                            rel="noopener noreferrer"
                            class="hover:text-neutral-200 transition-colors">github</a
                        >
                    </div>
                </div>

                <h1 class="mt-8 text-3xl md:text-5xl font-serif italic text-neutral-100 leading-tight">
                    {post.data.title}
                </h1>

                <div class="mt-4 text-sm text-neutral-500">
                    {
                        post.data.pubDate.toLocaleDateString("en-us", {
                            year: "numeric",
                            month: "long",
                            day: "numeric",
                        })
                    }
                </div>
            </div>
        </header>

        <main class="px-6 pb-24 mt-6">
            <article class="mx-auto max-w-2xl">
                <div class="prose max-w-none">
                    <Content />
                </div>
            </article>
        </main>
    </div>
</Layout>

<style is:global>
    .prose h2 {
        font-family: "Instrument Serif", Georgia, serif;
        font-size: 1.75rem;
        color: #e5e5e5;
        margin-top: 3rem;
        margin-bottom: 1rem;
        font-weight: normal;
        letter-spacing: -0.01em;
    }

    .prose h3 {
        font-family: "Instrument Serif", Georgia, serif;
        font-size: 1.35rem;
        color: #d4d4d4;
        margin-top: 2.5rem;
        margin-bottom: 0.75rem;
        font-weight: normal;
        letter-spacing: -0.01em;
    }

    .prose h4 {
        font-family: "Instrument Serif", Georgia, serif;
        font-size: 1.15rem;
        color: #d4d4d4;
        margin-top: 2rem;
        margin-bottom: 0.5rem;
        font-weight: normal;
    }

    .prose p {
        margin-bottom: 1.25rem;
        color: #a3a3a3;
        line-height: 1.7;
        font-size: 1.05rem;
    }

    .prose ul {
        list-style-type: disc;
        padding-left: 1.5rem;
        margin-bottom: 1.25rem;
        color: #a3a3a3;
    }

    .prose ol {
        list-style-type: decimal;
        padding-left: 1.5rem;
        margin-bottom: 1.25rem;
        color: #a3a3a3;
    }

    .prose li {
        margin-bottom: 0.5rem;
        line-height: 1.7;
    }

    .prose blockquote {
        border-left: 2px solid #228B22;
        padding-left: 1.25rem;
        margin-left: 0;
        margin-right: 0;
        font-style: italic;
        color: #d4d4d4;
    }

    .prose strong {
        color: #ffffff;
        font-weight: 600;
    }

    .prose a {
        color: #228B22;
        text-decoration: underline;
        text-underline-offset: 4px;
        transition: color 0.2s;
    }

    .prose a:hover {
        color: #32a852;
    }

    .prose code {
        color: #228B22;
        background-color: #0f2e1a;
        padding: 0.125rem 0.375rem;
        border-radius: 0.25rem;
        font-size: 0.875em;
        font-family: ui-monospace, SFMono-Regular, "SF Mono", Menlo, Consolas, monospace;
    }

    .prose pre {
        background-color: #071a0e;
        border: 1px solid #0f2e1a;
        border-radius: 0.5rem;
        padding: 1rem;
        margin-bottom: 1.25rem;
        overflow-x: auto;
    }

    .prose pre code {
        color: #228B22;
        background-color: transparent;
        padding: 0;
        border-radius: 0;
        font-size: 0.875rem;
        line-height: 1.7;
    }

    .prose table {
        width: 100%;
        border-collapse: collapse;
        margin-bottom: 1.25rem;
        font-size: 0.875rem;
    }

    .prose thead th {
        color: #e5e5e5;
        font-weight: 600;
        text-align: left;
        padding: 0.625rem 0.75rem;
        border-bottom: 1px solid #404040;
    }

    .prose tbody td {
        color: #a3a3a3;
        padding: 0.5rem 0.75rem;
        border-bottom: 1px solid #262626;
    }

    .prose tbody tr:hover {
        background-color: rgba(23, 23, 23, 0.5);
    }
</style>

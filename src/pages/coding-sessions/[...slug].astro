---
import { type CollectionEntry, getCollection } from "astro:content";
import Layout from "../../layouts/Layout.astro";
import Header from "../../components/Header.astro";
import SessionMeta from "../../components/SessionMeta.astro";
import "../../styles/content.css";

export async function getStaticPaths() {
  const sessions = await getCollection("coding-sessions", ({ data }) => !data.draft);
  return sessions.map((session) => ({
    params: { slug: session.slug },
    props: session,
  }));
}

type Props = CollectionEntry<"coding-sessions">;

const session = Astro.props;
const { Content } = await session.render();
---

<Layout title={`${session.data.title} — Coding Session`}>
  <div class="min-h-screen text-white bg-black">
    <Header active="sessions" tagline={false}>
      <h1 class="mt-8 text-3xl md:text-5xl font-serif italic text-neutral-100 leading-tight">
        {session.data.title}
      </h1>

      <SessionMeta
        pubDate={session.data.pubDate}
        cost={session.data.cost}
        tokens={session.data.tokens}
        class="mt-4"
      />

      <div class="mt-4 p-4 rounded-lg bg-neutral-900/60 border border-neutral-800">
        <p class="text-sm text-neutral-400 italic">{session.data.description}</p>
      </div>

      <div class="mt-4">
        <a
          href="/coding-sessions"
          class="text-xs font-mono text-neutral-600 hover:text-neutral-400 transition-colors"
        >
          ← back to sessions
        </a>
      </div>
    </Header>

    <main class="px-6 pb-24 mt-6">
      <article class="mx-auto max-w-2xl">
        <div class="transcript max-w-none">
          <Content />
        </div>
      </article>
    </main>
  </div>
</Layout>

<style is:global>
  /* Transcript-specific styles. Shared a/ul/ol/li/code/pre rules live in src/styles/content.css. */
  .transcript h4 {
    font-size: 0.95rem;
    font-weight: 700;
    margin-top: 2.5rem;
    margin-bottom: 0.75rem;
    padding: 0.5rem 0.75rem;
    border-radius: 0.375rem;
    display: inline-block;
  }

  .transcript h4:first-child {
    margin-top: 0;
  }

  .transcript p {
    margin-bottom: 1rem;
    color: #a3a3a3;
    line-height: 1.75;
    font-size: 0.95rem;
  }

  .transcript strong {
    color: #e5e5e5;
    font-weight: 600;
  }

  .transcript blockquote {
    border-left: 2px solid #262626;
    padding-left: 1rem;
    margin-left: 0;
    margin-right: 0;
    color: #737373;
    font-size: 0.85rem;
    line-height: 1.6;
  }

  .transcript blockquote strong {
    color: #a3a3a3;
  }

  .transcript hr {
    border-color: #262626;
    margin: 2rem 0;
  }

  /* Details/summary for sub-agent blocks */
  .transcript details {
    margin: 1rem 0;
    border: 1px solid #1a1a1a;
    border-radius: 0.5rem;
    background: #0a0a0a;
  }

  .transcript summary {
    cursor: pointer;
    padding: 0.75rem 1rem;
    font-size: 0.85rem;
    color: #737373;
    list-style: none;
    display: flex;
    align-items: center;
    gap: 0.5rem;
  }

  .transcript summary::-webkit-details-marker {
    display: none;
  }

  .transcript summary::before {
    content: "▶";
    font-size: 0.65rem;
    transition: transform 0.2s;
  }

  .transcript details[open] summary::before {
    transform: rotate(90deg);
  }

  .transcript summary strong {
    color: #a3a3a3;
    font-weight: 600;
  }

  .transcript details > p,
  .transcript details > ul,
  .transcript details > blockquote {
    padding: 0 1rem 0.75rem 1rem;
    margin-bottom: 0.5rem;
  }
</style>

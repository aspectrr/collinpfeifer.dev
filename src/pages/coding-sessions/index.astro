---
import Layout from "../../layouts/Layout.astro";
import Header from "../../components/Header.astro";
import { getCollection } from "astro:content";

const sessions = (
  await getCollection("coding-sessions", ({ data }) => !data.draft)
).sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf());
---

<Layout
  title="collinpfeifer.dev"
  description="Favorite coding session transcripts"
>
  <div class="min-h-screen text-white bg-black">
    <Header active="sessions">
      <h2 class="mt-12 text-3xl md:text-4xl font-serif italic text-neutral-200">Coding Sessions</h2>
      <p class="mt-2 text-neutral-500 text-sm">Transcripts from my favorite sessions with AI coding agents — and why I like them.</p>
    </Header>

    <main class="px-6 pb-24 mt-6">
      <div class="mx-auto max-w-2xl space-y-4">
        {
          sessions.map((session) => (
            <a
              href={`/coding-sessions/${session.slug}`}
              class="block p-6 rounded-lg bg-neutral-900/50 border border-neutral-800 hover:border-neutral-600 transition-all duration-300 no-underline hover:no-underline group"
            >
              <h3 class="text-xl font-serif italic text-neutral-200 group-hover:text-white transition-colors leading-snug">
                {session.data.title}
              </h3>
              <p class="mt-2 text-sm text-neutral-500 line-clamp-2">{session.data.description}</p>
              <div class="mt-3 flex items-center gap-3 flex-wrap">
                <time
                  datetime={session.data.pubDate.toISOString()}
                  class="text-xs font-mono text-neutral-600"
                >
                  {session.data.pubDate.toLocaleDateString("en-us", {
                    year: "numeric",
                    month: "long",
                    day: "numeric",
                  })}
                </time>
                {session.data.cost && (
                  <span class="text-xs font-mono text-neutral-700">· {session.data.cost}</span>
                )}
              </div>
            </a>
          ))
        }
      </div>
    </main>
  </div>
</Layout>

<style>
  a {
    text-decoration: none !important;
  }
  .line-clamp-2 {
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }
</style>

---
import Layout from "../layouts/Layout.astro";
import PokerChart from "../components/PokerChart.astro";
import Header from "../components/Header.astro";
---

<Layout
  title="collinpfeifer.dev"
  description="Live poker graph"
>
  <div class="min-h-screen text-white bg-black">
    <Header active="poker">
      <h2 class="mt-12 text-3xl md:text-4xl font-serif italic text-neutral-200">Poker</h2>
      <p class="mt-2 text-neutral-500 text-sm">Cumulative net across cash sessions. Pulled from my poker log.</p>
    </Header>

    <main class="px-6 pb-24 mt-6">
      <div class="mx-auto max-w-2xl">
        <PokerChart />
      </div>
    </main>
  </div>
</Layout>

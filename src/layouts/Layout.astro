---
import "../styles/global.css";

interface Props {
    title: string;
    description?: string;
}

const { title, description = "collinpfeifer.dev" } = Astro.props;
---

<!doctype html>
<html lang="en">
    <head>
        <meta charset="UTF-8" />
        <meta name="description" content={description} />
        <meta name="viewport" content="width=device-width" />
        <link rel="icon" href="/favicon.png" />
        <meta name="generator" content={Astro.generator} />
        <title>{title}</title>
        <link rel="preconnect" href="https://fonts.googleapis.com" />
        <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
        <link href="https://fonts.googleapis.com/css2?family=Instrument+Serif:ital@0;1&display=swap" rel="stylesheet" />
        <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/katex@0.16.11/dist/katex.min.css" />
    </head>
    <body class="bg-black text-white antialiased">
        <slot />
        <footer class="relative px-6 py-12 overflow-hidden">
            <img
                src="/art/G-fD3zSWMAAv6L4.jpeg"
                alt=""
                aria-hidden="true"
                class="absolute inset-0 w-full h-full object-cover object-bottom opacity-25 pointer-events-none"
                style="mask-image: linear-gradient(to top, black 70%, transparent); -webkit-mask-image: linear-gradient(to top, black 70%, transparent);"
            />
            <div
                class="relative z-10 flex flex-col md:flex-row justify-between items-center mx-auto max-w-2xl text-xs text-neutral-600 gap-4"
            >
                <span>&copy; 2026 Collin Pfeifer</span>
                <div class="flex gap-4 font-mono text-neutral-400">
                    <!-- <a
                        href="/blog"
                        class="hover:text-neutral-200 transition-colors">blog</a
                    >
                    <a
                        href="https://github.com/aspectrr"
                        target="_blank"
                        rel="noopener noreferrer"
                        class="hover:text-neutral-200 transition-colors"
                        >github</a
                    > --->
                    <a
                        href="tel:+3179955114"
                        class="hover:text-neutral-200 transition-colors"
                        target="_blank"
                        rel="noopener noreferrer">text</a
                    >
                    <a
                        href="mailto:cpfeifer@madcactus.org"
                        class="hover:text-neutral-200 transition-colors"
                        target="_blank"
                        rel="noopener noreferrer">email</a
                    >
                    <a
                        href="https://www.linkedin.com/in/collin-pfeifer/"
                        class="hover:text-neutral-200 transition-colors"
                        target="_blank"
                        rel="noopener noreferrer">linkedin</a
                    >
                </div>
            </div>
        </footer>
    </body>
</html>

<style is:global>
    :root {
        --bg: #000000;
        --fg: #ffffff;
        --fg-dim: #a3a3a3;
        --blue: #60a5fa;
    }

    html {
        background: var(--bg);
        color: var(--fg);
    }

    body {
        margin: 0;
        padding: 0;
        min-height: 100vh;
    }

    ::-webkit-scrollbar {
        width: 8px;
    }
    ::-webkit-scrollbar-track {
        background: var(--bg);
    }
    ::-webkit-scrollbar-thumb {
        background: #262626;
        border-radius: 4px;
    }

    a {
        text-decoration: none;
        transition: color 0.2s;
    }

    code {
        font-family:
            ui-monospace, SFMono-Regular, Menlo, Monaco, Consolas,
            "Liberation Mono", "Courier New", monospace;
    }

    pre {
        padding: 1rem;
        border-radius: 0.5rem;
        background-color: #171717 !important;
        border: 1px solid #262626;
    }
</style>
